<h1>Railsgram</h1>

<% if user_signed_in? %>

  <p>
    Добро пожаловать, <%= current_user.username %>
  </p>

  <%= button_to "Log out",
      destroy_user_session_path,
      method: :delete %>

<% else %>

  <%= link_to "Sign up",
      new_user_registration_path %>

  <br>

  <%= link_to "Log in",
      new_user_session_path %>

<% end %>