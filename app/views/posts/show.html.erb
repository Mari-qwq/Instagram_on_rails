<h1>
  <%= @post.caption %>
</h1>


<p>
  Author:
  <%= @post.user.username %>
</p>


<% if @post.image.attached? %>

  <%= image_tag @post.image %>

<% end %>

<% if current_user == @post.user %>

  <%= link_to "Edit",
      edit_post_path(@post) %>


  <%= button_to "Delete",
      post_path(@post),
      method: :delete %>

<% end %>


<%= link_to "Back",
    user_profile_path(@post.user.username) %>